GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.5-flash
# Optional: min ms between Gemini API calls on the Worker (default 15000). Set 0 to disable spacing.
# GEMINI_MIN_REQUEST_INTERVAL_MS=15000

# YouTube Data API v3 — captions.list + captions.download (optional; avoids scraping youtube.com/watch).
# Needs an API key (console) and an OAuth 2.0 access token with YouTube scope (e.g. youtube.force-ssl).
# YOUTUBE_KEY=
# YOUTUBE_ACCESS_TOKEN=
